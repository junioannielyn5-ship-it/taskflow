    <script>
    function toggleDarkMode() {
        var html = document.documentElement;
        html.classList.toggle('dark');
        if (html.classList.contains('dark')) {
            localStorage.setItem('mv-theme', 'dark');
        } else {
            localStorage.setItem('mv-theme', 'light');
        }
    }
    </script>
